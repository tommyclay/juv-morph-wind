#### 2. JUVENILE-ONLY COMPARISONS ####

dat_juv <- subset(dat, age == "Juvenile",)

# dealing with variables
hist(dat_juv$mass) 
hist(dat_juv$wingspan) 
hist(dat_juv$wingarea) 
hist(dat_juv$wingload)
hist(dat_juv$aspect)
