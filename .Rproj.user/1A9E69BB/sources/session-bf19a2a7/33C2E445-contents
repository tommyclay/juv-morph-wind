dat_juv$species <- as.factor(as.character(dat_juv$species))


# RUNNING LINEAR MODELS

# MASS ####DIFFERENT ####
mod_mass <- lm(mass ~ species, data = dat_juv)
mod_mass2 <- update(mod_mass,~.-species)
lrtest(mod_mass, mod_mass2)
# Model 1: mass ~ species
# Model 2: mass ~ 1
# #Df  LogLik Df  Chisq Pr(>Chisq)    
# 1   5 -477.36                         
# 2   2 -593.05 -3 231.36  < 2.2e-16 ***
summary(mod_mass)
# tukeys test to compare species
mass_tuk <- glht(mod_mass, linfct = mcp(species = "Tukey"))
summary(mass_tuk, test = adjusted("bonferroni"))
# Linear Hypotheses:
# Estimate Std. Error t value Pr(>|t|)    
# GHA - BBA == 0    116.9      221.6   0.527        1    
# WA - BBA == 0    8434.8      221.6  38.066  < 2e-16 ***
# WCP - BBA == 0  -1816.0      234.0  -7.760 1.03e-09 ***
# WA - GHA == 0    8317.9      221.6  37.539  < 2e-16 ***
# WCP - GHA == 0  -1932.9      234.0  -8.260 1.53e-10 ***
# WCP - WA == 0  -10250.8      234.0 -43.804  < 2e-16 ***

# residual checks
sim <- simulateResiduals(mod_mass)
plot(sim)
testDispersion(sim)
# mostly fine

