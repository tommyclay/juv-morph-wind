#### 5. TESTS ON ANGULAR DIFFERENCE ####

# calculate angular difference
dat$diff <- dat$wd_to-dat$bearing
dat$diff_180 <- dat$diff
dat$diff_180[dat$diff_180 > 180] <- dat$diff[dat$diff_180 > 180] -360
dat$diff_180[dat$diff_180 < -180] <- dat$diff[dat$diff_180 < -180] +360
ggplot(dat, aes(diff_180)) + geom_histogram() + facet_wrap(~species)
# convert to circular
dat$diff2 <- circular(dat$diff_180,  units = "degrees", template = "geographics", modulo = "asis", zero = 0)

rayleigh.test(dat$diff2[dat$species == "WALB"])
# Test Statistic:  0.3842 
# P-value:  0.1717 
rayleigh.test(dat$diff2[dat$species == "BBA"])
# Test Statistic:  0.0986 
# P-value:  0.8939 
rayleigh.test(dat$diff2[dat$species == "GHA"])
# Test Statistic:  0.5134 
# P-value:  0.0165
rayleigh.test(dat$diff2[dat$species == "WCP"])
# Test Statistic:  0.3317 
# P-value:  0.2724

