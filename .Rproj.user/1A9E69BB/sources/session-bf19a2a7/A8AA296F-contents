library(circular)
library(ggplot2)

#### 1. LOAD IN DATA AND CONVERTING TO CIRCULAR VARIABLE ####

dat <- read.csv("./Data_inputs/juv_depart_bearing.csv")

# turning to circular variable
dat$bearing <- circular(dat$bearing, units = "degrees", template = "geographics", zero = 0)
dat$wd_to <- circular(dat$wd_to, units = "degrees", template = "geographics", zero = 0)

# splitting by species
wa <- subset(dat, species == "WALB",)
gha <- subset(dat, species == "GHA",)
bba <- subset(dat, species == "BBA",)
wcp <- subset(dat, species == "WCP",)


#### 2. TESTS ON BEARINGS ####

##### 2A. DO BEARINGS DIFFER STATISTICALLY FROM UNIFORM? #####

rayleigh.test(wa$bearing)
# Test Statistic:  0.3774 
# P-value:  0.1831 
rayleigh.test(bba$bearing)
# Test Statistic:  0.4383 
# P-value:  0.0982 
rayleigh.test(gha$bearing)
# Test Statistic:  0.4609 
# P-value:  0.0385
rayleigh.test(wcp$bearing)
# Test Statistic:  0.6423 
# P-value:  0.0048

# as not all species are significantly directed, use a Watson's non-parametric test to compare between species #

##### 2B. BOOTSTRAP VERSION OF WATSONS NONPARAMETRIC TEST #####

# Watson’s Large-sample Nonparametric Test for testing the null hypothesis of a common mean direction for two or more distributions.
source("./Codes/bootstrap_watsons_function.R")

cdat <- circular(c(wa$bearing, bba$bearing, gha$bearing, wcp$bearing), 
                 type = "angles", units = "degrees", zero = 0, rotation = "counter")
n1 <- length(wa$bearing) ; n2 <- length(bba$bearing); n3 <- length(gha$bearing) ; n4 <- length(wcp$bearing) 
ndat <- c(n1, n2, n3, n4) ; g <- 4
YgObs <- YgVal(cdat, ndat, g) 
YgObs
#  10.34896
pchisq(YgObs, g-1, lower.tail=F)
#   0.01582132


##### 2C. CALCULATE MEAN DIRECTIONS #####

wa_dir <- mle.vonmises(wa$bearing)
as.numeric(wa_dir[2])+360
# 313.7639
wa_dir_ci <- mle.vonmises.bootstrap.ci(wa$bearing, alpha = 0.05)
wa_dir_ci 
# Bootstrap Confidence Intervals for Mean Direction and Concentration 
# Confidence Level:   95 % 
# Mean Direction:            Low = 37.2   High = -104.93 
# Concentration Parameter:   Low = 0.06   High = 2.13 
as.numeric(wa_dir_ci$mu.ci[2]) + 360
# 255.0704

bba_dir <- mle.vonmises(bba$bearing)
bba_dir
# 86.06
bba_dir_ci <- mle.vonmises.bootstrap.ci(bba$bearing, alpha = 0.05)
bba_dir_ci 
# Bootstrap Confidence Intervals for Mean Direction and Concentration 
# Confidence Level:   95 % 
# Mean Direction:            Low = 164.54   High = 47.69 
# Concentration Parameter:   Low = 0.11   High = 2.23 

gha_dir <- mle.vonmises(gha$bearing)
gha_dir
# 55.65
gha_dir_ci <- mle.vonmises.bootstrap.ci(gha$bearing, alpha = 0.05)
gha_dir_ci 
# Bootstrap Confidence Intervals for Mean Direction and Concentration 
# Confidence Level:   95 % 
# Mean Direction:            Low = 103.37   High = 14.61 
# Concentration Parameter:   Low = 0.25   High = 2.25 

wcp_dir <- mle.vonmises(wcp$bearing)
wcp_dir
# 21.76
wcp_dir_ci <- mle.vonmises.bootstrap.ci(wcp$bearing, alpha = 0.05)
wcp_dir_ci 
# Bootstrap Confidence Intervals for Mean Direction and Concentration 
