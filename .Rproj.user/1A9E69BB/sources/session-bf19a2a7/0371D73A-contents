### 5. RUNNING FULL MODEL ####

# creating splines
hat_df$sst_spline <- bs(hat_df$SST_pred, df = 4)
hat_df$sst_resid_spline <- bs(hat_df$SST_resid, df = 4)
hat_df$chl_spline <- bs(hat_df$CHL_pred, df = 4)
hat_df$chl_resid_spline <- bs(hat_df$CHL_resid, df = 4)
hat_df$mld_spline <- bs(hat_df$MLD_pred, df = 4)
hat_df$mld_resid_spline <- bs(hat_df$MLD_resid, df = 4)
hat_df$fpers_spline <- bs(hat_df$Fpers_pred, df = 4)
hat_df$fpers_resid_spline <- bs(hat_df$Fpers_resid, df = 4)
hat_df$eke_spline <- bs(hat_df$sqrt_EKE, df = 4)
hat_df$nasc_spline <- bs(hat_df$log_med_tot_nasc, df = 4)
hat_df$center_spline <- bs(hat_df$Med_centre_mass, df = 4)

# fitting full model
hat_m_full <- geeglm(DPH ~ sst_spline + sst_resid_spline + chl_spline +
                       chl_resid_spline + fpers_spline + fpers_resid_spline +
                       mld_spline + mld_resid_spline + eke_spline +
                       center_spline + nasc_spline + Lunar + 
                       Year, 
                     id = dol_block, 
                     corstr = "independence", 
                     family = gaussian, 
                     data = hat_df)

summary(hat_m_full)
acf(resid(hat_m_full)) # some slight autocorrelation
geepack::QIC(hat_m_full) 
# QIC      QICu Quasi Lik       CIC    params      QICC 
# 18769.8   18756.8   -9330.4      54.5      48.0   18660.4 

dwtest(hat_m_full, alternative = "two.sided")
# data:  hat_m_full
# DW = 1.3, p-value <2e-16
# alternative hypothesis: true autocorrelation is not 0

# calculating pseudo R2
null_mod <- geeglm(DPH ~ 1, id = dol_block, data = hat_df, family = gaussian(), corstr = "independence")
r2 <- function(null, mod, var) {
  dev_null <- sum((var - fitted(null))^2)
  dev_model <- sum((var - fitted(mod))^2)
  pseudo_r2 <- (1 - (dev_model / dev_null))*100
  return(pseudo_r2)
}
r2(null = null_mod, mod = hat_m_full, var = hat_df$DPH)
# Pseudo R-squared for GEE: 32.5 %


