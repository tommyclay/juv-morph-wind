# Function to get SE from geeglm from ChatGTP
predict_geeglm_se <- function(model, newdata) {
  # Predict values using the built-in predict function
  predicted_values <- predict(model, newdata = newdata, type = "response")
  
  # Calculate the linear predictors (Xβ)
  X <- model.matrix(delete.response(terms(model)), newdata)
  
  # Get the variance-covariance matrix of the coefficients
  vcov_matrix <- summary(model)$cov.scaled
  
  # Calculate the standard errors of the linear predictors
  se_linear_predictors <- sqrt(diag(X %*% vcov_matrix %*% t(X)))
  
  # Combine predictions and standard errors into a data frame
  result <- data.frame(fit = as.vector(predicted_values), se = as.vector(se_linear_predictors))
  return(result)
}

