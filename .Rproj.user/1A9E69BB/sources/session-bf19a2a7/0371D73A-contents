# POISSON #

m_hat_pois <- gam(DPH~ s(SST_pred,bs="cs",k=5)+s(SST_resid,bs="cs",k=5)+s(CHL_pred,bs="cs",k=5)+
                    s(CHL_resid,bs="cs",k=5)+s(MLD_resid,bs="cs",k=5)+s(Fpers_pred,bs="cs",k=5)+
                    s(Fpers_resid,bs="cs",k=5)+s(sqrt_EKE,bs="cs",k=5)+
                    s(Lunar,bs="cs",k=5)+s(Med_centre_mass,bs="cs",k=5)+
                    s(log_med_tot_nasc,bs="cs",k=5) + s(Random, bs = "cs", k = 5),
                  family = "poisson", data = hat_df, method = "ML")

# checking DHARMa residuals
sim <- simulateResiduals(m_hat_pois, n = 500, refit = F,
                         integerResponse = NULL, plot = F)
testTemporalAutocorrelation(sim, time = #kog.dat$Date_seq,
                              1:length(sim$scaledResiduals),
                            alternative = c("two.sided"), plot = T)
# data:  simulationOutput$scaledResiduals ~ 1
# DW = 1.2678, p-value < 2.2e-16
# alternative hypothesis: true autocorrelation is not 0

# TESTING OVERDISPERSION AND ZERO INFLATION USING DHARMA
testDispersion(sim)
# data:  simulationOutput
