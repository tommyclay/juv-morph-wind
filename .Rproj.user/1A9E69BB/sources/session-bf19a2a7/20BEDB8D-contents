# WCP #

speed_wcp_df <- subset(speed_df, species == "WCP",)
speed_wcp_df$id <- as.factor(as.character(speed_wcp_df$id))
wcp_speed_fin <- glmmTMB(speed ~ ws + ar1(seq_f + 0 | id), family = tweedie(), data = speed_wcp_df)
summary(wcp_speed_fin)

# choose mean of all weeks
pred_wcp <- expand.grid(id = levels(speed_wcp_df$id), 
                        ws = seq(min(speed_wcp_df$ws),max(speed_wcp_df$ws), 0.1)) 
pred_wcp$seq_f <- 1 # setting sequence to 1 - values won't affect mean response

pred_wcp2 <- predict(wcp_speed_fin, newdata = pred_wcp, se.fit=TRUE, type = "response")
pred_wcp$fit <- pred_wcp2$fit
pred_wcp$se.lwr <- pred_wcp$fit -(pred_wcp2$se.fit^2)
pred_wcp$se.upr <- pred_wcp$fit + (pred_wcp2$se.fit^2)
pred_wcp$ci.lwr <- pred_wcp$fit - pred_wcp2$se.fit*1.96
pred_wcp$ci.upr <- pred_wcp$fit + pred_wcp2$se.fit*1.96
pred_wcp_avg <- ddply(pred_wcp,.(ws), summarize, ci.upr = mean(ci.upr), ci.lwr = mean(ci.lwr), se.upr = mean(se.upr), se.lwr = mean(se.lwr),
                      fit = mean(fit))

