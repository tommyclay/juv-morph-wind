##### 2D. TRAVEL SPEEDS OVER TIME  #####

speed_df <- na.omit(data.frame(species = dat$species, id = dat$id, ws = dat$ws, days = dat$days,
                               speed = dat$speed, seq = dat$seq))
speed_df$id <- as.factor(as.character(speed_df$id))
speed_df$species <- as.factor(as.character(speed_df$species))

speed_df$seq_f <- factor(speed_df$seq)
speed_df$days_s <- scale(speed_df$days)

# RUNNING MODEL FOR ALL SPECIES 
speed_df$seq_f <- factor(speed_df$seq)
all_speed <- glmmTMB(speed ~ days*species + ar1(seq_f + 0 | id), family = tweedie(), data = speed_df)
dredge(all_speed)

pred_df <- expand.grid(id = levels(speed_df$id), 
                       days = seq(0, max(speed_df$days), 1))
pred_df$seq_f <- 1 
pred_df2 <- pred_df %>%
  left_join(speed_df %>% distinct(id, species), by = "id")

pred_df3 <- predict(all_speed, newdata = pred_df2, se.fit=TRUE, type = "response")
pred_df2$fit <- pred_df3$fit
pred_df2$se.lwr <- pred_df2$fit -pred_df3$se.fit
pred_df2$se.upr <- pred_df2$fit + pred_df3$se.fit
pred_df2$ci.lwr <- pred_df2$fit - pred_df3$se.fit*1.96
pred_df2$ci.upr <- pred_df2$fit + pred_df3$se.fit*1.96

# average for all ids (they are the same anyway)
pred_avg <- ddply(pred_df2,.(species, days), summarize, ci.upr = mean(ci.upr), ci.lwr = mean(ci.lwr), se.upr = mean(se.upr), se.lwr = mean(se.lwr),
                  fit = mean(fit))
# convert to km/hr
pred_avg$fit_km <- pred_avg$fit*3.6
pred_avg$ci.lwr_km <- pred_avg$ci.lwr*3.6
pred_avg$ci.upr_km <- pred_avg$ci.upr*3.6

