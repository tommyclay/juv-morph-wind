##### 2B. ORIENTATION TO WINDS #####

wdrel_df <- na.omit(data.frame(species = dat$species, id = dat$id, days = dat$days, seq = dat$seq, wdrel = dat$wdrel))
wdrel_df$id <- as.factor(as.character(wdrel_df$id))
wdrel_df$species <- as.factor(as.character(wdrel_df$species))

# rescale to between 0 and 1
wdrel_df$wdrel_scale <- wdrel_df$wdrel/180
eps <- 1e-4  
wdrel_df <- wdrel_df %>%
  mutate(wdrel_scale2 = wdrel_scale * (1 - 2*eps) + eps)
wdrel_df$seq_f <- factor(wdrel_df$seq)

wdrel_fin <- glmmTMB(wdrel_scale2 ~ days+species + ar1(seq_f + 0 | id),  
                         dispformula = ~ 1,    
                         family = beta_family(),data = wdrel_df)

# PREDICT ONTO NEW DATAFRAME
pred_df <- expand.grid(id = levels(wdrel_df$id), 
                       days = seq(0, max(wdrel_df$days), 1))
pred_df$seq_f <- 1 
pred_df2 <- pred_df %>%
  left_join(wdrel_df %>% distinct(id, species), by = "id")

pred_df3 <- predict(wdrel_fin, newdata = pred_df2, se.fit=TRUE, type = "response")
pred_df2$fit <- pred_df3$fit
pred_df2$se.lwr <- pred_df2$fit -pred_df3$se.fit
pred_df2$se.upr <- pred_df2$fit + pred_df3$se.fit
pred_df2$ci.lwr <- pred_df2$fit - pred_df3$se.fit*1.96
pred_df2$ci.upr <- pred_df2$fit + pred_df3$se.fit*1.96
# average for all ids (they are the same anyway)
pred_avg <- ddply(pred_df2,.(species, days), summarize, ci.upr = mean(ci.upr), ci.lwr = mean(ci.lwr), se.upr = mean(se.upr), se.lwr = mean(se.lwr),
                  fit = mean(fit))
# convert back to between 0 and 180
pred_avg$fit_180 <- pred_avg$fit*180
pred_avg$ci.lwr_180 <- pred_avg$ci.lwr*180
pred_avg$ci.upr_180 <- pred_avg$ci.upr*180

